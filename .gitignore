# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# Turbo
.turbo/

# Env
.env
.env.local
.env.*.local

# Vercel (project link + local auth artifacts — never commit)
.vercel

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# OS
Thumbs.db

# Coverage
coverage/
*.lcov

# Temp
*.tmp
tmp/

# Conclave — dogfood the memory substrate but keep the noisy parts out
# of git. Learned patterns (answer-keys + failure-catalog) ARE tracked
# so clones inherit them; raw events + federated cache aren't.
.conclave/episodic/
.conclave/federated/
.conclave/visual/

# marketplace screenshot artifacts (regenerated via packages/smoke-verifier/marketplace-capture.mjs)
apps/landing/public/screenshots/
packages/smoke-verifier/marketplace-*.mjs

# Wrangler / Miniflare local state (local D1, KV, caches). Generated by
# `wrangler dev` / `wrangler d1 execute --local`. Local-only — never commit.
apps/central-plane/.wrangler/

.vercel
