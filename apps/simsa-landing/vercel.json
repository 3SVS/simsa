{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "trysimsa.com" }],
      "destination": "https://simsa.dev/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.trysimsa.com" }],
      "destination": "https://simsa.dev/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.simsa.dev" }],
      "destination": "https://simsa.dev/:path*",
      "permanent": true
    }
  ]
}
