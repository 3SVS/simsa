{
  "name": "@conclave-ai/workspace-preview",
  "version": "0.0.0",
  "private": true,
  "description": "Pure deterministic preview helpers for Simsa workspace planning, shared by the dashboard and MCP Basic. No React/Next/browser/network/env/mutation/hosted-execution/payment/secrets.",
  "license": "FSL-1.1-Apache-2.0",
  "type": "module",
  "main": "./src/index.mjs",
  "types": "./src/index.d.mts",
  "exports": {
    ".": {
      "types": "./src/index.d.mts",
      "import": "./src/index.mjs"
    },
    "./safety": {
      "types": "./src/safety.d.mts",
      "import": "./src/safety.mjs"
    },
    "./intake": {
      "types": "./src/intake.d.mts",
      "import": "./src/intake.mjs"
    },
    "./intake-prd": {
      "types": "./src/intake-prd.d.mts",
      "import": "./src/intake-prd.mjs"
    },
    "./intake-url": {
      "types": "./src/intake-url.d.mts",
      "import": "./src/intake-url.mjs"
    },
    "./intake-github-repo": {
      "types": "./src/intake-github-repo.d.mts",
      "import": "./src/intake-github-repo.mjs"
    },
    "./intake-ai-built-app": {
      "types": "./src/intake-ai-built-app.d.mts",
      "import": "./src/intake-ai-built-app.mjs"
    },
    "./intake-acceptance-map": {
      "types": "./src/intake-acceptance-map.d.mts",
      "import": "./src/intake-acceptance-map.mjs"
    },
    "./intake-stage-plan": {
      "types": "./src/intake-stage-plan.d.mts",
      "import": "./src/intake-stage-plan.mjs"
    },
    "./intake-agent-run-plan": {
      "types": "./src/intake-agent-run-plan.d.mts",
      "import": "./src/intake-agent-run-plan.mjs"
    },
    "./intake-evidence-plan": {
      "types": "./src/intake-evidence-plan.d.mts",
      "import": "./src/intake-evidence-plan.mjs"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test test/*.test.mjs",
    "clean": "rm -rf .tsbuildinfo"
  }
}
